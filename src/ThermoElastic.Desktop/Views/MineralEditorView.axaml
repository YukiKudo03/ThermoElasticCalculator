<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.MineralEditorView"
             x:DataType="vm:MineralEditorViewModel">

    <ScrollViewer>
        <StackPanel Spacing="8" Margin="8">
            <TextBlock Text="Mineral Library" FontWeight="Bold" FontSize="18" />

            <!-- File Operations -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Load .mine" Click="OnLoadMine" />
                <Button Content="Save .mine" Click="OnSaveMine" />
                <Button Content="Import CSV" Click="OnImportCsv" />
                <Button Content="Export CSV" Click="OnExportCsv" />
            </StackPanel>

            <!-- Parameter Input -->
            <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mineral Name" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MineralName}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Paper Name" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding PaperName}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="NumAtoms (n)" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NumAtoms}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Molar Volume (V0)" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MolarVolume}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Molar Weight (Mw)" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MolarWeight}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="K0 [GPa]" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding KZero}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="K0'" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding K1Prime}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="3" Grid.Column="2" Text="K0''" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding K2Prime}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="G0 [GPa]" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding GZero}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="4" Grid.Column="2" Text="G0'" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding G1Prime}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="G0''" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding G2Prime}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="5" Grid.Column="2" Text="Debye Temp (theta0)" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding DebyeTempZero}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Gamma0" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding GammaZero}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="6" Grid.Column="2" Text="q0" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding QZero}" Margin="0,0,0,4" />

                <TextBlock Grid.Row="7" Grid.Column="0" Text="etaS0" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding EhtaZero}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="7" Grid.Column="2" Text="Ref Temp [K]" VerticalAlignment="Center" Margin="0,0,8,4" />
                <TextBox Grid.Row="7" Grid.Column="3" Text="{Binding RefTemp}" Margin="0,0,0,4" />
            </Grid>

            <!-- Test Calculation -->
            <TextBlock Text="Test Calculation" FontWeight="Bold" FontSize="14" Margin="0,8,0,4" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="P [GPa]:" VerticalAlignment="Center" />
                <TextBox Text="{Binding TestPressure}" Width="100" />
                <TextBlock Text="T [K]:" VerticalAlignment="Center" />
                <TextBox Text="{Binding TestTemperature}" Width="100" />
                <Button Content="Calculate" Command="{Binding CalcTestCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding TestResult}" FontFamily="Consolas,monospace" Margin="0,4" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
