<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.BayesianInversionView"
             x:DataType="vm:BayesianInversionViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Bayesian MCMC Inversion" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="True Mean:" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding TrueMean}" Width="80" FormatString="F1" />
            <TextBlock Text="Sigma:" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding TrueSigma}" Width="80" FormatString="F1" />
            <TextBlock Text="Samples:" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding NSamples}" Width="80" Minimum="100" Maximum="100000" />
            <Button Content="Run MCMC" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
            <TextBlock Text="{Binding RecoveredMean, StringFormat='Recovered Mean: {0:F3}'}" />
            <TextBlock Text="{Binding AcceptanceRate, StringFormat='Acceptance: {0:P0}'}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
        <DataGrid ItemsSource="{Binding ChainResults}" AutoGenerateColumns="True" />
    </DockPanel>
</UserControl>
