<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.MagmaOceanView"
             x:DataType="vm:MagmaOceanViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Magma Ocean Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Pressure}" Minimum="0" Maximum="140" Width="120" />
            <TextBlock Text="T (K):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="10000" Width="120" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding Solidus, StringFormat='Solidus: {0:F1} K'}" />
            <TextBlock Text="{Binding Liquidus, StringFormat='Liquidus: {0:F1} K'}" />
            <TextBlock Text="{Binding MeltFraction, StringFormat='Melt Fraction: {0:F4}'}" />
            <TextBlock Text="{Binding MeltingState, StringFormat='State: {0}'}" FontWeight="Bold" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
