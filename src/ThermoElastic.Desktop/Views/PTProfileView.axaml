<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.PTProfileView"
             x:DataType="vm:PTProfileViewModel">

    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="P-T Profile Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Load Mineral..." Click="OnLoadMineral" />
            <Button Content="Load PT Profile..." Click="OnLoadProfile" />
            <Button Content="Save PT Profile..." Click="OnSaveProfile" />
            <Button Content="Add P-T Point" Command="{Binding AddPTDataCommand}" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
            <Button Content="Export CSV..." Click="OnExportCsv" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="{Binding MineralName}" Margin="0,0,0,8" />

        <!-- Split: PT input | Results -->
        <Grid ColumnDefinitions="*,*">
            <DataGrid Grid.Column="0" ItemsSource="{Binding PTDataList}" AutoGenerateColumns="True" Margin="0,0,8,0" />
            <DataGrid Grid.Column="1" ItemsSource="{Binding Results}" AutoGenerateColumns="True" IsReadOnly="True" />
        </Grid>
    </DockPanel>
</UserControl>
