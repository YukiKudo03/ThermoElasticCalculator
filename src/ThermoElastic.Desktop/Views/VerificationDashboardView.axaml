<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.VerificationDashboardView"
             x:DataType="vm:VerificationDashboardViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Verification Dashboard" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Mineral:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMineralIndex}" Width="200" />
                <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Pressure}" Minimum="0.001" Maximum="150" Width="100" />
                <TextBlock Text="T (K):" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="5000" Width="100" />
                <Button Content="Verify" Command="{Binding CalculateCommand}" />
            </StackPanel>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding MaxwellResidual, StringFormat='Maxwell Residual: {0:E3}'}" />
            <TextBlock Text="{Binding GibbsHelmholtzResidual, StringFormat='Gibbs-Helmholtz Residual: {0:E3}'}" />
            <TextBlock Text="{Binding EntropyResidual, StringFormat='Entropy Residual: {0:E3}'}" />
            <TextBlock Text="{Binding BulkModulusResidual, StringFormat='Bulk Modulus Residual: {0:E3}'}" />
            <TextBlock Text="{Binding KsKtResidual, StringFormat='KS/KT Residual: {0:E3}'}" />
            <TextBlock Text="{Binding IsValid, StringFormat='Valid: {0}'}" FontWeight="Bold" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
