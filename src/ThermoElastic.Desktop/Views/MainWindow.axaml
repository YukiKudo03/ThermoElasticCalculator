<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
        xmlns:views="using:ThermoElastic.Desktop.Views"
        x:Class="ThermoElastic.Desktop.Views.MainWindow"
        Title="{Binding Title}"
        Width="1100" Height="750"
        x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Navigation Panel with ScrollViewer -->
        <ScrollViewer DockPanel.Dock="Left" Width="220">
            <StackPanel Background="#F0F0F0" Spacing="4" Margin="8">
                <TextBlock Text="ThermoElastic Calculator" FontWeight="Bold" FontSize="14" Margin="0,8,0,12" TextWrapping="Wrap" />

                <!-- Core Tools -->
                <TextBlock Text="Core Tools" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,4,0,2" />
                <Button Content="Mineral Library" Command="{Binding ShowMineralEditorCommand}" HorizontalAlignment="Stretch" />
                <Button Content="PT Profile" Command="{Binding ShowPTProfileCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Mixture" Command="{Binding ShowMixtureCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Rock Calculator" Command="{Binding ShowRockCalculatorCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Results" Command="{Binding ShowResultsCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Database" Command="{Binding ShowDatabaseCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Chart" Command="{Binding ShowChartCommand}" HorizontalAlignment="Stretch" />

                <!-- EOS & Shock -->
                <Separator Margin="0,6" />
                <TextBlock Text="EOS &amp; Shock" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,2" />
                <Button Content="Hugoniot" Command="{Binding ShowHugoniotCommand}" HorizontalAlignment="Stretch" />
                <Button Content="EOS Fitter" Command="{Binding ShowEOSFitterCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Param. Fitter" Command="{Binding ShowThermoElasticFitterCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Verification" Command="{Binding ShowVerificationDashboardCommand}" HorizontalAlignment="Stretch" />

                <!-- Phase Equilibria -->
                <Separator Margin="0,6" />
                <TextBlock Text="Phase Equilibria" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,2" />
                <Button Content="Phase Diagram" Command="{Binding ShowPhaseDiagramCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Post-Perovskite" Command="{Binding ShowPostPerovskiteCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Geobarometry" Command="{Binding ShowClassicalGeobarometryCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Elastic Geobar." Command="{Binding ShowGeobarometryCommand}" HorizontalAlignment="Stretch" />

                <!-- Mantle & Deep Earth -->
                <Separator Margin="0,6" />
                <TextBlock Text="Mantle &amp; Deep Earth" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,2" />
                <Button Content="Sensitivity Kernel" Command="{Binding ShowSensitivityKernelCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Anelasticity" Command="{Binding ShowAnelasticityCommand}" HorizontalAlignment="Stretch" />
                <Button Content="LLSVP" Command="{Binding ShowLLSVPCommand}" HorizontalAlignment="Stretch" />
                <Button Content="ULVZ" Command="{Binding ShowULVZCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Slab Model" Command="{Binding ShowSlabModelCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Planetary Interior" Command="{Binding ShowPlanetaryInteriorCommand}" HorizontalAlignment="Stretch" />

                <!-- Material Properties -->
                <Separator Margin="0,6" />
                <TextBlock Text="Material Properties" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,2" />
                <Button Content="Spin Crossover" Command="{Binding ShowSpinCrossoverCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Thermal Cond." Command="{Binding ShowThermalConductivityCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Electrical Cond." Command="{Binding ShowElectricalConductivityCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Elastic Tensor" Command="{Binding ShowElasticTensorCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Oxygen Fugacity" Command="{Binding ShowOxygenFugacityCommand}" HorizontalAlignment="Stretch" />

                <!-- Composition & Fluids -->
                <Separator Margin="0,6" />
                <TextBlock Text="Composition &amp; Fluids" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,2" />
                <Button Content="Composition Inv." Command="{Binding ShowCompositionInverterCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Iron Partitioning" Command="{Binding ShowIronPartitioningCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Water Content" Command="{Binding ShowWaterContentCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Magma Ocean" Command="{Binding ShowMagmaOceanCommand}" HorizontalAlignment="Stretch" />

                <!-- Inversion & ML -->
                <Separator Margin="0,6" />
                <TextBlock Text="Inversion &amp; ML" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,2" />
                <Button Content="ML Data" Command="{Binding ShowMLDataCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Bayesian Inversion" Command="{Binding ShowBayesianInversionCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Lookup Table" Command="{Binding ShowLookupTableCommand}" HorizontalAlignment="Stretch" />

                <Separator Margin="0,8" />
            </StackPanel>
        </ScrollViewer>

        <!-- Content Area -->
        <ContentControl Content="{Binding CurrentView}" Margin="8">
            <ContentControl.DataTemplates>
                <!-- Core Tools -->
                <DataTemplate DataType="vm:MineralEditorViewModel"><views:MineralEditorView /></DataTemplate>
                <DataTemplate DataType="vm:PTProfileViewModel"><views:PTProfileView /></DataTemplate>
                <DataTemplate DataType="vm:MixtureViewModel"><views:MixtureView /></DataTemplate>
                <DataTemplate DataType="vm:RockCalculatorViewModel"><views:RockCalculatorView /></DataTemplate>
                <DataTemplate DataType="vm:ResultsViewModel"><views:ResultsView /></DataTemplate>
                <DataTemplate DataType="vm:MineralDatabaseViewModel"><views:MineralDatabaseView /></DataTemplate>
                <DataTemplate DataType="vm:ChartViewModel"><views:ChartView /></DataTemplate>
                <!-- EOS & Shock -->
                <DataTemplate DataType="vm:HugoniotViewModel"><views:HugoniotView /></DataTemplate>
                <DataTemplate DataType="vm:EOSFitterViewModel"><views:EOSFitterView /></DataTemplate>
                <DataTemplate DataType="vm:ThermoElasticFitterViewModel"><views:ThermoElasticFitterView /></DataTemplate>
                <DataTemplate DataType="vm:VerificationDashboardViewModel"><views:VerificationDashboardView /></DataTemplate>
                <!-- Phase Equilibria -->
                <DataTemplate DataType="vm:PhaseDiagramExplorerViewModel"><views:PhaseDiagramExplorerView /></DataTemplate>
                <DataTemplate DataType="vm:PostPerovskiteViewModel"><views:PostPerovskiteView /></DataTemplate>
                <DataTemplate DataType="vm:ClassicalGeobarometryViewModel"><views:ClassicalGeobarometryView /></DataTemplate>
                <DataTemplate DataType="vm:GeobarometryViewModel"><views:GeobarometryView /></DataTemplate>
                <!-- Mantle & Deep Earth -->
                <DataTemplate DataType="vm:SensitivityKernelViewModel"><views:SensitivityKernelView /></DataTemplate>
                <DataTemplate DataType="vm:AnelasticityViewModel"><views:AnelasticityView /></DataTemplate>
                <DataTemplate DataType="vm:LLSVPViewModel"><views:LLSVPView /></DataTemplate>
                <DataTemplate DataType="vm:ULVZViewModel"><views:ULVZView /></DataTemplate>
                <DataTemplate DataType="vm:SlabModelViewModel"><views:SlabModelView /></DataTemplate>
                <DataTemplate DataType="vm:PlanetaryInteriorViewModel"><views:PlanetaryInteriorView /></DataTemplate>
                <!-- Material Properties -->
                <DataTemplate DataType="vm:SpinCrossoverViewModel"><views:SpinCrossoverView /></DataTemplate>
                <DataTemplate DataType="vm:ThermalConductivityViewModel"><views:ThermalConductivityView /></DataTemplate>
                <DataTemplate DataType="vm:ElectricalConductivityViewModel"><views:ElectricalConductivityView /></DataTemplate>
                <DataTemplate DataType="vm:ElasticTensorViewModel"><views:ElasticTensorView /></DataTemplate>
                <DataTemplate DataType="vm:OxygenFugacityViewModel"><views:OxygenFugacityView /></DataTemplate>
                <!-- Composition & Fluids -->
                <DataTemplate DataType="vm:CompositionInverterViewModel"><views:CompositionInverterView /></DataTemplate>
                <DataTemplate DataType="vm:IronPartitioningViewModel"><views:IronPartitioningView /></DataTemplate>
                <DataTemplate DataType="vm:WaterContentViewModel"><views:WaterContentView /></DataTemplate>
                <DataTemplate DataType="vm:MagmaOceanViewModel"><views:MagmaOceanView /></DataTemplate>
                <!-- Inversion & ML -->
                <DataTemplate DataType="vm:MLDataViewModel"><views:MLDataView /></DataTemplate>
                <DataTemplate DataType="vm:BayesianInversionViewModel"><views:BayesianInversionView /></DataTemplate>
                <DataTemplate DataType="vm:LookupTableViewModel"><views:LookupTableView /></DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </DockPanel>
</Window>
