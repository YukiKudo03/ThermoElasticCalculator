<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
        xmlns:views="using:ThermoElastic.Desktop.Views"
        x:Class="ThermoElastic.Desktop.Views.MainWindow"
        Title="{Binding Title}"
        Width="1000" Height="700"
        x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Navigation Panel -->
        <StackPanel DockPanel.Dock="Left" Width="200" Background="#F0F0F0" Spacing="8" Margin="8">
            <TextBlock Text="ThermoElastic Calculator" FontWeight="Bold" FontSize="14" Margin="0,8,0,16" TextWrapping="Wrap" />
            <Button Content="Mineral Library" Command="{Binding ShowMineralEditorCommand}" HorizontalAlignment="Stretch" />
            <Button Content="PT Profile" Command="{Binding ShowPTProfileCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Mixture" Command="{Binding ShowMixtureCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Rock Calculator" Command="{Binding ShowRockCalculatorCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Results" Command="{Binding ShowResultsCommand}" HorizontalAlignment="Stretch" />
            <Separator Margin="0,8" />
            <Button Content="Database" Command="{Binding ShowDatabaseCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Chart" Command="{Binding ShowChartCommand}" HorizontalAlignment="Stretch" />
            <Separator Margin="0,8" />
            <Button Content="Hugoniot" Command="{Binding ShowHugoniotCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Phase Diagram" Command="{Binding ShowPhaseDiagramCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Lookup Table" Command="{Binding ShowLookupTableCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Sensitivity Kernel" Command="{Binding ShowSensitivityKernelCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Planetary Interior" Command="{Binding ShowPlanetaryInteriorCommand}" HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- Content Area -->
        <ContentControl Content="{Binding CurrentView}" Margin="8">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:MineralEditorViewModel">
                    <views:MineralEditorView />
                </DataTemplate>
                <DataTemplate DataType="vm:PTProfileViewModel">
                    <views:PTProfileView />
                </DataTemplate>
                <DataTemplate DataType="vm:MixtureViewModel">
                    <views:MixtureView />
                </DataTemplate>
                <DataTemplate DataType="vm:RockCalculatorViewModel">
                    <views:RockCalculatorView />
                </DataTemplate>
                <DataTemplate DataType="vm:ResultsViewModel">
                    <views:ResultsView />
                </DataTemplate>
                <DataTemplate DataType="vm:MineralDatabaseViewModel">
                    <views:MineralDatabaseView />
                </DataTemplate>
                <DataTemplate DataType="vm:ChartViewModel">
                    <views:ChartView />
                </DataTemplate>
                <DataTemplate DataType="vm:HugoniotViewModel">
                    <views:HugoniotView />
                </DataTemplate>
                <DataTemplate DataType="vm:PhaseDiagramExplorerViewModel">
                    <views:PhaseDiagramExplorerView />
                </DataTemplate>
                <DataTemplate DataType="vm:LookupTableViewModel">
                    <views:LookupTableView />
                </DataTemplate>
                <DataTemplate DataType="vm:SensitivityKernelViewModel">
                    <views:SensitivityKernelView />
                </DataTemplate>
                <DataTemplate DataType="vm:PlanetaryInteriorViewModel">
                    <views:PlanetaryInteriorView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </DockPanel>
</Window>
