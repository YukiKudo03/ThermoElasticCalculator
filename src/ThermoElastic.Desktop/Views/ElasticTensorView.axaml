<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.ElasticTensorView"
             x:DataType="vm:ElasticTensorViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Elastic Tensor Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Mineral:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding TensorNames}" SelectedIndex="{Binding SelectedTensorIndex}" Width="150" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Direction X:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding DirectionX}" Minimum="-1" Maximum="1" Increment="0.1" Width="100" />
                <TextBlock Text="Y:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding DirectionY}" Minimum="-1" Maximum="1" Increment="0.1" Width="100" />
                <TextBlock Text="Z:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding DirectionZ}" Minimum="-1" Maximum="1" Increment="0.1" Width="100" />
                <Button Content="Calculate" Command="{Binding CalculateCommand}" />
            </StackPanel>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding Vp, StringFormat='Vp: {0:F1} m/s'}" />
            <TextBlock Text="{Binding Vs1, StringFormat='Vs1: {0:F1} m/s'}" />
            <TextBlock Text="{Binding Vs2, StringFormat='Vs2: {0:F1} m/s'}" />
            <TextBlock Text="{Binding MaxAnisotropy, StringFormat='Max Anisotropy: {0:F1}%'}" />
            <TextBlock Text="{Binding KVRH, StringFormat='K_VRH: {0:F1} GPa'}" />
            <TextBlock Text="{Binding GVRH, StringFormat='G_VRH: {0:F1} GPa'}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
