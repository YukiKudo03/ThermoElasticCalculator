<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.AnelasticityView"
             x:DataType="vm:AnelasticityViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Anelasticity Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />

        <!-- Row 1: Mineral + T,P,f -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
            <TextBlock Text="Mineral:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMineralIndex}" Width="200" />
            <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Pressure}" Minimum="0" Maximum="200" Width="100" />
            <TextBlock Text="T (K):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="5000" Width="100" />
            <TextBlock Text="f (Hz):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Frequency}" Minimum="0.001" Maximum="100" Increment="0.1" Width="80" />
        </StackPanel>

        <!-- Row 2: Model selection + parameters -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
            <TextBlock Text="Model:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ModelNames}" SelectedIndex="{Binding SelectedModelIndex}" Width="200" />
            <TextBlock Text="d (mm):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding GrainSize_mm}" Minimum="0.001" Maximum="100" Increment="1" Width="90" />
            <TextBlock Text="H₂O (ppm):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding WaterContent}" Minimum="0" Maximum="3000" Increment="10" Width="90" />
            <TextBlock Text="Melt φ:" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding MeltFraction}" Minimum="0" Maximum="0.2" Increment="0.005" FormatString="F3" Width="90" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>

        <!-- Results -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding QS, StringFormat='QS: {0:F1}'}" />
            <TextBlock Text="{Binding VpElastic, StringFormat='Vp elastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding VsElastic, StringFormat='Vs elastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding VpAnelastic, StringFormat='Vp anelastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding VsAnelastic, StringFormat='Vs anelastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding DeltaVsPercent, StringFormat='ΔVs: {0:F3} %'}" />
            <TextBlock Text="{Binding DeltaVpPercent, StringFormat='ΔVp: {0:F3} %'}" />
        </StackPanel>

        <!-- Status -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
