<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.AnelasticityView"
             x:DataType="vm:AnelasticityViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Anelasticity Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Mineral:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMineralIndex}" Width="200" />
            <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Pressure}" Minimum="0" Maximum="200" Width="100" />
            <TextBlock Text="T (K):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="5000" Width="100" />
            <TextBlock Text="Freq (Hz):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Frequency}" Minimum="0.001" Maximum="100" Width="80" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4">
            <TextBlock Text="{Binding QS, StringFormat='QS: {0:F1}'}" />
            <TextBlock Text="{Binding VpElastic, StringFormat='Vp elastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding VsElastic, StringFormat='Vs elastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding VpAnelastic, StringFormat='Vp anelastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding VsAnelastic, StringFormat='Vs anelastic: {0:F1} m/s'}" />
            <TextBlock Text="{Binding DeltaVsPercent, StringFormat='Delta Vs: {0:F2} %'}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
