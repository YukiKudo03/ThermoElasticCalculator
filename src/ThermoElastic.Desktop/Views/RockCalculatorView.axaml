<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.RockCalculatorView"
             x:DataType="vm:RockCalculatorViewModel">

    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Rock Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Add Mineral..." Click="OnAddMineral" />
            <Button Content="Load Rock..." Click="OnLoadRock" />
            <Button Content="Save Rock..." Click="OnSaveRock" />
        </StackPanel>

        <!-- Rock Name -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Rock Name:" VerticalAlignment="Center" />
            <TextBox Text="{Binding RockName}" Width="200" />
        </StackPanel>

        <!-- Mineral List -->
        <DataGrid DockPanel.Dock="Top" ItemsSource="{Binding MineralEntries}" AutoGenerateColumns="False" Height="200" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mineral" Binding="{Binding MineralName}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Volume Ratio" Binding="{Binding VolumeRatio}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- P-T and Method -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="P [GPa]:" VerticalAlignment="Center" />
            <TextBox Text="{Binding Pressure}" Width="100" />
            <TextBlock Text="T [K]:" VerticalAlignment="Center" />
            <TextBox Text="{Binding Temperature}" Width="100" />
            <TextBlock Text="Method:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding MethodNames}" SelectedIndex="{Binding SelectedMethodIndex}" Width="120" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Foreground="Gray" Margin="0,4" />

        <!-- Results -->
        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="True" IsReadOnly="True" />
    </DockPanel>
</UserControl>
