<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.ResultsView"
             x:DataType="vm:ResultsViewModel">

    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Results" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Export CSV..." Click="OnExportCsv" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="True" IsReadOnly="True" />
    </DockPanel>
</UserControl>
