<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.WaterContentView"
             x:DataType="vm:WaterContentViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Water Content Estimator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Mineral:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMineralIndex}" Width="200" />
            <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Pressure}" Minimum="0" Maximum="140" Width="120" />
            <TextBlock Text="T (K):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="5000" Width="120" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="H2O (wt%):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding WaterContent_wt}" Minimum="0" Maximum="10" Width="100" />
            <TextBlock Text="Observed dlnVs:" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding ObservedDlnVs}" Minimum="-0.2" Maximum="0" Width="120" Increment="0.005" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding Vs_hydrous, StringFormat='Vs (hydrous): {0:F1} m/s'}" FontWeight="Bold" />
            <TextBlock Text="{Binding EstimatedWater, StringFormat='Estimated H2O: {0:F3} wt%'}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
