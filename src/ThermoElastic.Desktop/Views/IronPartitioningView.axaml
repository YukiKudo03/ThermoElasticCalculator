<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.IronPartitioningView"
             x:DataType="vm:IronPartitioningViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Iron Partitioning Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="MgPv:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMgPvIndex}" Width="120" />
                <TextBlock Text="FePv:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedFePvIndex}" Width="120" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="MgFp:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMgFpIndex}" Width="120" />
                <TextBlock Text="FeFp:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedFeFpIndex}" Width="120" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Bulk XFe:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding BulkXFe}" Minimum="0.01" Maximum="0.5" Increment="0.01" Width="100" />
                <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Pressure}" Minimum="0" Maximum="150" Width="100" />
                <TextBlock Text="T (K):" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="5000" Width="100" />
                <Button Content="Calculate" Command="{Binding CalculateCommand}" />
            </StackPanel>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding XFePv, StringFormat='XFe_pv: {0:F4}'}" />
            <TextBlock Text="{Binding XFeFp, StringFormat='XFe_fp: {0:F4}'}" />
            <TextBlock Text="{Binding KD, StringFormat='KD: {0:F4}'}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
