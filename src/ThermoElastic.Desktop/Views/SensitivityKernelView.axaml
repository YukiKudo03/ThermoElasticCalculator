<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.SensitivityKernelView"
             x:DataType="vm:SensitivityKernelViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Sensitivity Kernel Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Mineral:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMineralIndex}" Width="200" />
            <TextBlock Text="P [GPa]:" VerticalAlignment="Center" />
            <TextBox Text="{Binding Pressure}" Width="80" />
            <TextBlock Text="T [K]:" VerticalAlignment="Center" />
            <TextBox Text="{Binding Temperature}" Width="80" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,8,0,0">
            <TextBlock Text="{Binding DlnVp_dT, StringFormat='d ln(Vp)/dT = {0:E4} [1/K]'}" />
            <TextBlock Text="{Binding DlnVs_dT, StringFormat='d ln(Vs)/dT = {0:E4} [1/K]'}" />
            <TextBlock Text="{Binding DlnRho_dT, StringFormat='d ln(rho)/dT = {0:E4} [1/K]'}" />
            <TextBlock Text="{Binding RThermal, StringFormat='R_thermal = {0:F3}'}" FontWeight="Bold" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
        <Border />
    </DockPanel>
</UserControl>
