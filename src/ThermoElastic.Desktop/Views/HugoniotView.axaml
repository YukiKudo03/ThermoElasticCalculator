<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.HugoniotView"
             x:DataType="vm:HugoniotViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Hugoniot Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Mineral:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding MineralNames}" SelectedIndex="{Binding SelectedMineralIndex}" Width="200" />
            <TextBlock Text="Points:" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding NumPoints}" Minimum="5" Maximum="100" Width="80" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="True" />
    </DockPanel>
</UserControl>
