<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThermoElastic.Desktop.ViewModels"
             x:Class="ThermoElastic.Desktop.Views.OxygenFugacityView"
             x:DataType="vm:OxygenFugacityViewModel">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Oxygen Fugacity Calculator" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Buffer:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding BufferNames}" SelectedIndex="{Binding SelectedBufferIndex}" Width="120" />
            <TextBlock Text="T (K):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Temperature}" Minimum="300" Maximum="5000" Width="120" />
            <TextBlock Text="P (GPa):" VerticalAlignment="Center" />
            <NumericUpDown Value="{Binding Pressure}" Minimum="0.0001" Maximum="100" Width="120" />
            <Button Content="Calculate" Command="{Binding CalculateCommand}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="log(fO2):" VerticalAlignment="Center" />
            <TextBlock Text="{Binding LogFO2, StringFormat={}{0:F4}}" VerticalAlignment="Center" FontWeight="Bold" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" />
    </DockPanel>
</UserControl>
